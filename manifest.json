{
  "manifest_version": 3,
  "name": "Tab Groups",
  "version": "1.1.17",
  "description": "Archive browser windows' tabs into recallable tab groups, suitable for control by voice.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Archive this window",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "open-list": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "MacCtrl+Shift+L"
      },
      "description": "Open the tab groups list"
    },
    "archive-window": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "MacCtrl+Shift+E"
      },
      "description": "Archive the current window"
    }
  },
  "content_scripts": [
    {
      "matches": ["file:///*/tab_groups_list_page.html"],
      "js": ["src/lib/format.js", "src/content.js"]
    }
  ],
  "permissions": ["tabs", "storage", "downloads", "offscreen", "favicon", "unlimitedStorage"]
}
